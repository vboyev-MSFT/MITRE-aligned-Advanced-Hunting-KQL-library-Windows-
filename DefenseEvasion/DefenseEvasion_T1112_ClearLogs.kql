// Tactic: Defense Evasion | Technique: T1112 Indicator Removal on Host (clear logs)
DeviceProcessEvents
| where Timestamp > ago(lookback)
| where (FileName =~ "wevtutil.exe" and ProcessCommandLine has_any (" cl "," clear-log "))
   or (FileName in~ ("powershell.exe","pwsh.exe") and ProcessCommandLine has_any ("Clear-EventLog","Remove-EventLog"))
| project Timestamp, DeviceName, FileName, ProcessCommandLine
